# === YNAB API ===
YNAB_API_TOKEN=your-ynab-api-token
YNAB_BUDGET_ID=last-used
YNAB_ACCOUNT_ID=your-checking-account-uuid

# === Monitor Settings ===
# MONITOR_DAYS=         # empty = end of current month
# MIN_BALANCE=0         # floor for dynamic thresholds (dollars)
# YNAB_TARGET_BUFFER_DAYS=10
# YNAB_ALERT_BUFFER_DAYS=5

# === CC Payment Tracking ===
# YNAB_CC_CLOSE_DATES=CardName:15,OtherCard:22
# YNAB_CC_CATEGORIES=   # comma-separated category IDs, empty = all
# YNAB_CC_CREATE_PAYMENTS=false

# === Notifications ===
# APPRISE_URLS=discord://webhook_id/webhook_token
# NOTIFIARR_API_KEY=your-notifiarr-key
# NOTIFIARR_CHANNEL_ID=123456789
# NOTIFIARR_UPDATE_CHANNEL_ID=  # defaults to NOTIFIARR_CHANNEL_ID

# === Scheduling ===
# SCHEDULE=08:00        # "HH:MM" for daily, "6h" for interval
# UPDATE_SCHEDULE=      # separate schedule for balance updates
# UPDATE_APPRISE_URLS=  # separate notification URLs for updates

# === Amazon Settings ===
# AMAZON_USER=you@example.com
# AMAZON_PASSWORD=your-amazon-password
# AMAZON_OTP_SECRET_KEY= # TOTP secret for auto-MFA
# AMAZON_DEBUG=false
# AMAZON_FULL_DETAILS=true

# === Amazon → YNAB Matching ===
# YNAB_PAYEE_NAME_TO_BE_PROCESSED=Amazon - Needs Memo
# YNAB_PAYEE_NAME_PROCESSING_COMPLETED=Amazon
# YNAB_USE_MARKDOWN=false
# MATCH_EMPTY_MEMO=false
# AMOUNT_MATCH_TOLERANCE=2.00
# DATE_MISMATCH_TOLERANCE_DAYS=0
# AUTO_ACCEPT_DATE_MISMATCH=false
# NON_INTERACTIVE=false

# === AI Summarization ===
# USE_AI_SUMMARIZATION=false
# OPENAI_API_KEY=your-openai-key

# === Cache ===
# CACHE_DIR=/tmp/ynab-tools
# AMAZON_CACHE_DIR=~/.cache/ynamazon

# === General ===
# DRY_RUN=false
# TZ=America/New_York
